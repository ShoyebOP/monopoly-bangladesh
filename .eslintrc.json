{
  "languageOptions": {
    "ecmaVersion": 2024,
    "sourceType": "module",
    "globals": {
      "console": "readonly",
      "process": "readonly",
      "Buffer": "readonly",
      "require": "readonly",
      "module": "readonly",
      "__dirname": "readonly",
      "__filename": "readonly",
      "exports": "readonly",
      "structuredClone": "readonly",
      "setTimeout": "readonly",
      "setInterval": "readonly",
      "clearTimeout": "readonly",
      "clearInterval": "readonly"
    }
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "no-undef": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"],
    "no-var": "error",
    "prefer-const": "error",
    "no-console": "off"
  }
}
